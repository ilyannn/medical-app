{
  "name": "open-household-medical-app",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "An open-source, macOS-first household medical organizer with a Bun web app, Hono API, SQLite persistence, and a local MCP server.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilyannn/medical-app.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"bun run dev:web\" \"bun run dev:server\"",
    "dev:web": "vite --host 127.0.0.1 --port 4173",
    "dev:server": "bun --hot src/server/index.ts",
    "build": "bun run build:web && bun run build:server",
    "build:web": "vite build",
    "build:server": "bun build src/server/index.ts --target bun --outdir dist/server && bun build src/mcp/index.ts --target bun --outdir dist/mcp",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "lint": "bun run lint:ts && bun run lint:sql",
    "lint:ts": "biome check . && tsc --noEmit",
    "lint:sql": "bash ./scripts/lint-sql.sh",
    "scan:secrets": "bash ./scripts/scan-secrets.sh",
    "test": "bun run test:unit && bun run test:e2e",
    "setup:hooks": "bash ./scripts/setup-git-hooks.sh",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:live": "vitest run src/test/live --passWithNoTests",
    "test:native": "swift build --package-path native/macos-bridge && vitest run src/test/native --passWithNoTests",
    "db:migrate": "bun run src/server/db/migrate.ts",
    "mcp": "bun run src/mcp/index.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/sdk": "^1.17.3",
    "@tanstack/react-query": "^5.66.8",
    "@tanstack/react-table": "^8.21.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.0.9",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.5",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.9"
  }
}
